# Database — PostgreSQL (Neon, Supabase, Railway, or local)
DATABASE_URL="postgresql://user:password@host:5432/chronocraft"

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET="your-32-char-minimum-secret-here-change-this"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Admin bootstrap (used only in seed script)
ADMIN_EMAIL="admin@chronocraft.com"
ADMIN_PASSWORD="change-this-in-production"
