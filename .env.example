# Database — PostgreSQL (Neon, Supabase, Railway, or local)
DATABASE_URL="postgresql://user:password@host:5432/chronocraft"

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET="your-32-char-minimum-secret-here-change-this"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Cloudinary product image uploads
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Admin bootstrap (used only in seed script)
ADMIN_EMAIL="admin@chronocraft.com"
ADMIN_PASSWORD="change-this-in-production"

# ─── Deposit payment coordinates (shown to customers as instructions) ─────────
# Bank transfer
DEPOSIT_BANK_NAME="Banque Populaire"
DEPOSIT_BANK_RIB="000 000 0000000000000000 00"
DEPOSIT_BANK_HOLDER="ChronoCraft SARL"
# CashPlus
DEPOSIT_CASHPLUS_NAME="ChronoCraft"
DEPOSIT_CASHPLUS_PHONE="06 00 00 00 00"
# Wafacash
DEPOSIT_WAFACASH_NAME="ChronoCraft"
DEPOSIT_WAFACASH_PHONE="06 00 00 00 00"
# Support / WhatsApp shown for help
DEPOSIT_WHATSAPP="06 00 00 00 00"

# ─── Transactional email (optional) ───────────────────────────────────────────
# When set, important notifications (order confirmed, deposit approved/rejected,
# shipped, password changed, security alerts) also send an email via Resend.
# Leave empty to disable email; in-app notifications still work.
RESEND_API_KEY=""
EMAIL_FROM="ChronoCraft <no-reply@chronocraft.ma>"
